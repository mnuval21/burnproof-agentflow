{
  "name": "create-burnproof-agentflow",
  "version": "0.1.0",
  "description": "Install BurnProof-AgentFlow into any project — AI agent framework for spec-driven development",
  "type": "module",
  "bin": {
    "create-burnproof-agentflow": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18",
    "dev": "tsx src/index.ts",
